// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id     Int     @id @default(autoincrement())
  nome   String
  email  String  @unique
  senha  String
  curso  String
  imgUrl String?
  bio    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postagens   Postagem[]
  comentarios Comentario[]
  curtidas    Curtida[]

  @@map("usuarios")
}

model Postagem {
  id        Int     @id @default(autoincrement())
  titulo    String
  descricao String
  imgUrl    String?

  autorId Int
  autor   Usuario @relation(fields: [autorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comentarios Comentario[]
  curtidas    Curtida[]

  @@map("postagens")
}

model Comentario {
  id       Int    @id @default(autoincrement())
  conteudo String

  autorId Int
  autor   Usuario @relation(fields: [autorId], references: [id], onDelete: Cascade)

  postagemId Int
  postagem   Postagem @relation(fields: [postagemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("comentarios")
}

model Curtida {
  id Int @id @default(autoincrement())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  postagemId Int
  postagem   Postagem @relation(fields: [postagemId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, postagemId])
  @@map("curtidas")
}

model Log {
  id        Int      @id @default(autoincrement())
  acao      String
  usuarioId Int?
  createdAt DateTime @default(now())

  @@map("logs")
}
